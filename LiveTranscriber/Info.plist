<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Live Transcriber</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Audio Recording</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.audio</string>
				<string>public.mpeg-4-audio</string>
				<string>com.apple.m4a-audio</string>
				<string>public.mp3</string>
				<string>public.wav</string>
				<string>com.microsoft.waveform-audio</string>
				<string>public.aiff-audio</string>
				<string>public.aifc-audio</string>
			</array>
		</dict>
	</array>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Live Transcriber</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.iamwilliamli.LiveTranscriber</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>livetranscriber</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Live Transcriber does not use the camera. Apple's capture framework is used only for microphone recording.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Used only when you choose to attach a location to a saved recording.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Used to record audio for live transcription.</string>
	<key>NSRemindersFullAccessUsageDescription</key>
	<string>Used only when you choose to add extracted action items to Reminders.</string>
	<key>NSRemindersUsageDescription</key>
	<string>Used only when you choose to add extracted action items to Reminders.</string>
	<key>NSScreenCaptureUsageDescription</key>
	<string>Used only when you choose Screen Audio to transcribe audio made available by another app.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Used to turn recorded speech into live transcription text.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSUbiquitousContainers</key>
	<dict>
		<key>iCloud.com.iamwilliamli.LiveTranscriber</key>
		<dict>
			<key>NSUbiquitousContainerIsDocumentScopePublic</key>
			<false/>
			<key>NSUbiquitousContainerName</key>
			<string>Live Transcriber</string>
			<key>NSUbiquitousContainerSupportedFolderLevels</key>
			<string>Any</string>
		</dict>
	</dict>
	<key>UIAppFonts</key>
	<array>
		<string>RedditSans-Regular.ttf</string>
		<string>RedditSans-Medium.ttf</string>
		<string>RedditSans-SemiBold.ttf</string>
		<string>RedditSans-Bold.ttf</string>
		<string>RedditSans-Italic.ttf</string>
		<string>Baloo2-Variable.ttf</string>
	</array>
	<key>UIApplicationShortcutItems</key>
	<array>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>record.circle</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Start Recording</string>
			<key>UIApplicationShortcutItemType</key>
			<string>com.iamwilliamli.LiveTranscriber.startRecording</string>
		</dict>
	</array>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>remote-notification</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
	<key>UILaunchStoryboardName</key>
	<string></string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
</dict>
</plist>
