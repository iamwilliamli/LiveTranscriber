    "qwen3_asr.model.description" : {
      "comment" : "Description of Qwen3-ASR capabilities in Settings.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On-device post-recording transcription with multilingual recognition and audio-based timestamps. Speaker separation is not included."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在设备上进行录音后转录，支持多语言识别和基于音频的时间戳；暂不包含说话人分离。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在裝置上進行錄音後轉錄，支援多語言辨識和基於音訊的時間戳；暫不包含說話人分離。"
          }
        }
      }
    },
