    "recordings.gemini.manual.import_instructions" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Copy Gemini's complete JSON response, then paste it below. This workflow does not use this app's Gemini API key or token counter. Importing replaces the transcript and speaker labels after saving a restorable copy of the current transcript."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "复制 Gemini 返回的完整 JSON，然后粘贴到下方。此流程不会使用本 App 的 Gemini API 密钥，也不会计入本 App 的 Token 统计。导入前会保存当前转录的可恢复副本，随后替换转录文本和说话人标签。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "複製 Gemini 傳回的完整 JSON，然後貼到下方。此流程不會使用本 App 的 Gemini API 金鑰，也不會計入本 App 的 Token 統計。匯入前會儲存目前轉錄的可還原副本，之後取代轉錄文字和說話者標籤。"
          }
        }
      }
    },
