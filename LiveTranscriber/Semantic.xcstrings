    "source.license_note" : {
      "comment" : "Source information page licensing note.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Projekt verwendet eine source-available Lizenz, keine OSI-genehmigte Open-Source-Lizenz; kommerzielle Forks oder abgeleitete Produkte müssen sichtbare In-App-Namensnennung beibehalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The project uses a source-available license, not an OSI-approved open-source license; commercial forks or derivative products need to keep visible in-app attribution."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このプロジェクトはsource-availableライセンスを使用しており、OSI承認のオープンソースライセンスではありません。商用フォークまたは派生製品では、アプリ内に見える形で帰属表示を維持する必要があります。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het project gebruikt een source-available licentie, geen door de OSI goedgekeurde open-sourcelicentie; commerciële forks of afgeleide producten moeten zichtbare in-appvermelding behouden."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "项目采用 source-available 授权，不是 OSI-approved open-source license；商业 fork 或衍生产品需要在 app 内保留可见署名。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "專案採用 source-available 授權，不是 OSI-approved open-source license；商業 fork 或衍生產品需要在 app 內保留可見署名。"
          }
        }
      }
