        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "后台音频只用于录音或播放继续进行，不用于其他后台任务。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "背景音訊只用於讓錄音或播放繼續進行，不用於其他背景任務。"
          }
        }
      }
    },
    "settings.permission.camera" : {
      "comment" : "Permission usage explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
