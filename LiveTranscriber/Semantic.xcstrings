    "settings.permission.background_audio": {
      "comment": "Permission usage explanation.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Background audio is only used to let recording or playback continue, not for other background tasks."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "后台音频只用于录音或播放继续进行，不用于其他后台任务。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hintergrundaudio wird nur verwendet, damit Aufnahme oder Wiedergabe fortgesetzt werden können, nicht für andere Hintergrundaufgaben."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Achtergrondaudio wordt alleen gebruikt om opname of afspelen te laten doorgaan, niet voor andere achtergrondtaken."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックグラウンド音声は録音または再生を継続するためだけに使用され、その他のバックグラウンドタスクには使用されません。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "背景音訊只用於讓錄音或播放繼續進行，不用於其他背景任務。"
          }
        }
      }
    },
    "settings.permission.camera": {
      "comment": "Permission usage explanation.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The camera is not used for photos or video. The camera permission description only satisfies Apple capture framework review requirements."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "相机不用于拍照或录像；相机权限说明仅用于满足 Apple capture framework 的审核要求。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Kamera wird nicht für Fotos oder Videos verwendet. Die Kameraberechtigung erfüllt nur die Prüfanforderungen des Apple Capture Frameworks."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De camera wordt niet gebruikt voor foto's of video. De cameratoestemmingsbeschrijving is er alleen voor Apple capture framework-reviewvereisten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラは写真やビデオには使用されません。カメラ権限の説明は、Appleのキャプチャフレームワークの審査要件を満たすためだけのものです。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "相機不會用於拍照或錄影；相機權限說明僅用於滿足 Apple capture framework 的審核要求。"
          }
        }
      }
    },
    "settings.permission.location": {
      "comment": "Permission usage explanation.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Location permission is only used when the user chooses to add a location while saving a recording."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "位置权限只在保存录音时选择添加地理位置时使用。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Standortberechtigung wird nur verwendet, wenn der Benutzer beim Speichern einer Aufnahme einen Standort hinzufügen möchte."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Locatietoestemming wordt alleen gebruikt wanneer de gebruiker ervoor kiest een locatie toe te voegen bij het bewaren van een opname."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報の権限は、録音を保存するときにユーザーが位置情報の追加を選択した場合にのみ使用されます。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "位置權限只會在儲存錄音時選擇加入地理位置時使用。"
          }
        }
      }
    },
    "settings.permission.microphone": {
      "comment": "Permission usage explanation.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Microphone permission is only used for recording and live transcription."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "麦克风权限只用于录音和实时转录。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Mikrofonberechtigung wird nur für Aufnahme und Live-Transkription verwendet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Microfoontoestemming wordt alleen gebruikt voor opnemen en live transcriptie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイク権限は録音とライブ文字起こしにのみ使用されます。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "麥克風權限只用於錄音和即時轉錄。"
          }
        }
      }
    },
    "settings.permission.speech": {
      "comment": "Permission usage explanation.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Speech recognition permission is only used to convert user-selected recordings into text."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语音识别权限只用于把用户选择的录音转成文本。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Spracherkennungsberechtigung wird nur verwendet, um vom Benutzer ausgewählte Aufnahmen in Text umzuwandeln."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spraakherkenningstoestemming wordt alleen gebruikt om door de gebruiker gekozen opnamen naar tekst om te zetten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声認識の権限は、ユーザーが選択した録音をテキストに変換するためだけに使用されます。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "語音識別權限只用於把使用者選擇的錄音轉成文字。"
          }
        }
      }
    },
