    "settings.icloud_sync.description": {
      "comment": "iCloud sync setting description.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, new recordings and the index are saved to the app-private iCloud container. When disabled, they are saved in the local app-private container by default."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，新的录音和索引会保存到 app 私有 iCloud container；关闭时默认保存在本机 app 私有容器。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, werden neue Aufnahmen und der Index im app-privaten iCloud-Container gespeichert. Wenn deaktiviert, werden sie standardmäßig im lokalen app-privaten Container gespeichert."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wanneer ingeschakeld, worden nieuwe opnamen en de index opgeslagen in de app-private iCloud-container. Wanneer uitgeschakeld, worden ze standaard opgeslagen in de lokale privécontainer van de app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、新しい録音とインデックスはアプリ専用iCloudコンテナに保存されます。無効にすると、既定ではローカルのアプリ専用コンテナに保存されます。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後，新的錄音和索引會儲存到 app 私有 iCloud container；關閉時預設儲存在本機 app 私有容器。"
          }
        }
      }
    },
