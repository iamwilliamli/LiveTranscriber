    "qwen3_asr.developer.streaming_long_audio" : {
      "comment" : "Developer option title for bounded-memory Qwen3-ASR transcription.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qwen3-ASR: Lange Aufnahmen streamen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qwen3-ASR Long-Recording Streaming"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qwen3-ASR 長時間録音ストリーミング"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qwen3-ASR: lange opnamen streamen"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qwen3-ASR 流式处理长录音"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qwen3-ASR 串流處理長錄音"
          }
        }
      }
    },
    "qwen3_asr.developer.streaming_long_audio.description" : {
      "comment" : "Developer option description for bounded-memory Qwen3-ASR transcription.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Experimentell. Liest Audio in 30-Sekunden-Fenstern und gibt PCM während der Transkription frei. Ist die Option aus, wird zuerst die gesamte Aufnahme geladen. Änderungen gelten für neue Qwen3-ASR-Aufträge."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Experimental. Read audio in 30-second windows and release PCM as transcription advances. When off, the entire recording is loaded first. Changes apply to new Qwen3-ASR jobs."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "試験的機能です。音声を30秒単位で読み込み、文字起こしの進行に合わせてPCMを解放します。オフの場合は録音全体を先に読み込みます。変更は新しいQwen3-ASR処理から適用されます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Experimenteel. Leest audio in vensters van 30 seconden en geeft PCM vrij terwijl de transcriptie vordert. Indien uitgeschakeld wordt eerst de volledige opname geladen. Wijzigingen gelden voor nieuwe Qwen3-ASR-taken."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "实验性功能。以30秒窗口读取音频，并随转录进度释放PCM；关闭时会先载入整段录音。修改仅影响之后开始的Qwen3-ASR任务。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "實驗性功能。以30秒視窗讀取音訊，並隨轉錄進度釋放PCM；關閉時會先載入整段錄音。變更僅影響之後開始的Qwen3-ASR工作。"
          }
        }
      }
    },
