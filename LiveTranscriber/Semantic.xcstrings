    "icloud.container_unavailable.recording_stays_local" : {
      "comment" : "Per-recording detail shown when the iCloud container is unavailable.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der iCloud-Container ist derzeit nicht verfügbar, daher bleibt diese Aufnahme vorerst lokal."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The iCloud container is currently unavailable, so this recording stays local for now."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloudコンテナは現在利用できないため、この録音は当面ローカルに保持されます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De iCloud-container is momenteel niet beschikbaar, dus deze opname blijft voorlopig lokaal."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud container 当前不可用，录音会先保留在本机。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud container 目前無法使用，錄音會先保留在本機。"
          }
        }
      }
    },
    "icloud.detail.container_unavailable" : {
      "comment" : "Storage detail shown when iCloud is enabled but the container is unavailable.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud ist aktiviert, aber der iCloud-Container ist derzeit nicht erreichbar. Bis er verfügbar ist, werden Aufnahmen im lokalen app-privaten Container behalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud is on, but the iCloud container is not currently reachable. Until it is available, recordings are kept in the local app-private container."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloudはオンですが、iCloudコンテナに現在アクセスできません。利用可能になるまで、録音はローカルのアプリ専用コンテナに保持されます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud is ingeschakeld, maar de iCloud-container is momenteel niet bereikbaar. Tot die beschikbaar is, blijven opnamen in de lokale privécontainer van de app."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 已开启，但当前无法访问 iCloud container；在可用前会暂存到本机 app 私有容器。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 已開啟，但目前無法存取 iCloud container；在可用前會暫存到本機 app 私有容器。"
          }
        }
      }
    },
    "icloud.detail.disabled" : {
      "comment" : "Storage detail shown when iCloud storage is disabled.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud ist deaktiviert. Aufnahmedateien und Index werden im lokalen app-privaten Container gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud is off. Recording files and the index are stored in the local app-private container."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloudはオフです。録音ファイルとインデックスはローカルのアプリ専用コンテナに保存されます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud is uitgeschakeld. Opnamebestanden en de index worden opgeslagen in de lokale privécontainer van de app."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 未开启，录音文件和索引保存在本机 app 私有容器。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 未開啟，錄音檔案和索引會儲存在本機 app 私有容器。"
          }
        }
      }
    },
    "icloud.detail.enabled" : {
      "comment" : "Storage detail shown when iCloud storage is enabled and available.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud ist aktiviert. Aufnahmedateien werden im Data-Verzeichnis des app-privaten iCloud-Containers gespeichert, und der Index wird über eine private CloudKit-Datenbank synchronisiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud is on. Recording files are saved in the Data directory of the app-private iCloud container, and the index syncs through a CloudKit private database."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloudはオンです。録音ファイルはアプリ専用iCloudコンテナのDataディレクトリに保存され、インデックスはCloudKitのプライベートデータベース経由で同期されます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud is ingeschakeld. Opnamebestanden worden opgeslagen in de Data-map van de app-private iCloud-container en de index synchroniseert via een private CloudKit-database."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 已开启，录音文件保存到 app 私有 iCloud container 的 Data 目录，索引通过 CloudKit private database 同步。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCloud 已開啟，錄音檔案會儲存到 app 私有 iCloud container 的 Data 目錄，索引會透過 CloudKit private database 同步。"
          }
        }
      }
    },
    "icloud.detail.switching_storage" : {
      "comment" : "Storage detail shown while moving between local and iCloud storage.",
