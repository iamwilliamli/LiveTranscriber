    "settings.permission.background_audio" : {
      "comment" : "Permission usage explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hintergrundaudio wird nur verwendet, damit Aufnahme oder Wiedergabe fortgesetzt werden können, nicht für andere Hintergrundaufgaben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Background audio is only used to let recording or playback continue, not for other background tasks."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バックグラウンド音声は録音または再生を継続するためだけに使用され、その他のバックグラウンドタスクには使用されません。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Achtergrondaudio wordt alleen gebruikt om opname of afspelen te laten doorgaan, niet voor andere achtergrondtaken."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "后台音频只用于录音或播放继续进行，不用于其他后台任务。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "背景音訊只用於讓錄音或播放繼續進行，不用於其他背景任務。"
          }
        }
      }
    },
    "settings.permission.camera" : {
      "comment" : "Permission usage explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Kamera wird nicht für Fotos oder Videos verwendet. Die Kameraberechtigung erfüllt nur die Prüfanforderungen des Apple Capture Frameworks."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The camera is not used for photos or video. The camera permission description only satisfies Apple capture framework review requirements."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カメラは写真やビデオには使用されません。カメラ権限の説明は、Appleのキャプチャフレームワークの審査要件を満たすためだけのものです。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De camera wordt niet gebruikt voor foto's of video. De cameratoestemmingsbeschrijving is er alleen voor Apple capture framework-reviewvereisten."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "相机不用于拍照或录像；相机权限说明仅用于满足 Apple capture framework 的审核要求。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "相機不會用於拍照或錄影；相機權限說明僅用於滿足 Apple capture framework 的審核要求。"
          }
        }
      }
    },
    "settings.permission.location" : {
      "comment" : "Permission usage explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
