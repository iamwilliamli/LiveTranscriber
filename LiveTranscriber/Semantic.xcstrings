    "onboarding.feature.live.detail" : {
      "comment" : "Onboarding feature description for live transcription.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nimm Besprechungen, Vorlesungen, Anrufe oder Notizen mit zeitcodierten Transkriptzeilen auf, die direkt nach dem Stoppen bereit sind."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Record meetings, lectures, calls, or field notes with timed transcript lines ready as soon as you stop."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "会議、講義、通話、フィールドノートを録音し、停止後すぐにタイム付きの文字起こしを確認できます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neem vergaderingen, colleges, gesprekken of veldnotities op met getimede transcriptregels zodra je stopt."
