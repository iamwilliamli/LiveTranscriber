      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Schlüssel wird im Schlüsselbund gespeichert und von diesem iPhone direkt zur Verbindung mit OpenAI verwendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
