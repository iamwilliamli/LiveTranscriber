    "settings.openai_api_key.manual_retranscription_uploads_audio" : {
      "comment" : "Settings privacy help text for manual OpenAI retranscription.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenAI wird nur verwendet, wenn du für eine gespeicherte Aufnahme manuell OpenAI-Transkription auswählst; das Audio dieser Aufnahme wird direkt von diesem iPhone an OpenAI gesendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenAI is used only when you manually choose OpenAI transcription for a saved recording; that recording audio is sent directly from this iPhone to OpenAI."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenAIは、保存済み録音でOpenAI文字起こしを手動で選んだ場合にのみ使われます。その録音音声はこのiPhoneからOpenAIへ直接送信されます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "OpenAI wordt alleen gebruikt wanneer je handmatig OpenAI-transcriptie kiest voor een opgeslagen opname; de audio van die opname wordt rechtstreeks vanaf deze iPhone naar OpenAI verzonden."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有在你手动为已保存录音选择 OpenAI 转录时才会使用 OpenAI；该录音音频会由这台 iPhone 直接发送给 OpenAI。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有在你手動為已儲存錄音選擇 OpenAI 轉錄時才會使用 OpenAI；該錄音音訊會由這台 iPhone 直接傳送給 OpenAI。"
          }
        }
      }
    },
