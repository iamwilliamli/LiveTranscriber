          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De broncode van LiveTranscriber is openbaar beschikbaar om van te leren, te forken en verder te ontwikkelen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
