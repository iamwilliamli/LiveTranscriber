    "app_intents.open_recording.description" : {
      "comment" : "App Intent description for opening a recording.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffnet eine Aufnahme in Live Transcriber."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opens a recording in Live Transcriber."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Live Transcriberで録音を開きます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opent een opname in Live Transcriber."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
