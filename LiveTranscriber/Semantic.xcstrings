    "settings.storage.delete_removes_managed_files" : {
      "comment" : "Storage privacy explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Löschen einer Aufnahme entfernt die von der App verwaltete Audiodatei und den Transkripttext."
          }
        },
        "en" : {
          "stringUnit" : {
