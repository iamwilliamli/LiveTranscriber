    "settings.privacy.developer_cannot_access_content" : {
      "comment" : "Privacy explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Audio und Transkripte werden nicht auf Entwickler-Server hochgeladen, und der Entwickler kann nicht auf Benutzerinhalte zugreifen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Audio and transcripts are not uploaded to developer servers, and the developer cannot access user content."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音声と文字起こしは開発者のサーバーにアップロードされず、開発者はユーザーのコンテンツにアクセスできません。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Audio en transcripties worden niet naar ontwikkelaarsservers geüpload en de ontwikkelaar heeft geen toegang tot gebruikersinhoud."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音频和转录不会上传到开发者服务器，开发者无法访问用户内容。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音訊和轉錄不會上傳到開發者伺服器，開發者無法存取使用者內容。"
          }
        }
      }
    },
    "settings.privacy.no_developer_servers" : {
      "comment" : "Privacy explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es werden keine vom Entwickler betriebenen Server, keine Drittanbieter-Analysen, keine Werbung und kein Tracking verwendet. Der optionale Download des lokalen Whisper-Modells verbindet sich nur mit Hugging Face, wenn du auf „Ausgewähltes Modell laden“ tippst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No developer-operated servers, third-party analytics, ads, or tracking are used. The optional Local Whisper model download connects to Hugging Face only when you tap Download Selected Model."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "開発者が運用するサーバー、サードパーティ分析、広告、トラッキングは使用しません。任意のローカルWhisperモデルのダウンロードは、「選択したモデルをダウンロード」をタップした場合にのみHugging Faceに接続します。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er worden geen door de ontwikkelaar beheerde servers, analyses van derden, advertenties of tracking gebruikt. De optionele download van het lokale Whisper-model maakt alleen verbinding met Hugging Face wanneer je op Geselecteerd model downloaden tikt."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不使用开发者运营的服务器、第三方分析、广告或追踪。可选的本地 Whisper 模型下载只会在你点按“下载所选模型”时连接 Hugging Face。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不使用開發者營運的伺服器、第三方分析、廣告或追蹤。可選的本機 Whisper 模型下載只會在你點一下「下載所選模型」時連線 Hugging Face。"
          }
        }
      }
    },
