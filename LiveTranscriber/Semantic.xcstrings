        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "录制会议、课程、通话或现场笔记，停止后即可获得带时间线的转录内容。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "錄製會議、課程、通話或現場筆記，停止後即可取得帶時間軸的轉錄內容。"
