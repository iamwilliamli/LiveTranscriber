    "settings.storage.index_sync_private_database" : {
      "comment" : "Storage privacy explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Aufnahmenindex wird standardmäßig lokal gespeichert. Wenn iCloud aktiviert ist, wird er über die private CloudKit-Datenbank des Benutzers synchronisiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The recording index is stored locally by default. When iCloud is enabled, it syncs through the user's own CloudKit private database."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "録音インデックスは既定でローカルに保存されます。iCloudが有効な場合、ユーザー自身のCloudKitプライベートデータベースを通じて同期されます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De opname-index wordt standaard lokaal opgeslagen. Wanneer iCloud is ingeschakeld, synchroniseert deze via de eigen private CloudKit-database van de gebruiker."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "录音索引默认存在本机；开启 iCloud 后通过 CloudKit private database 同步到用户自己的 iCloud。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "錄音索引預設存在本機；開啟 iCloud 後會透過使用者自己的 CloudKit private database 同步。"
          }
        }
      }
    },
    "settings.storage.local_then_icloud" : {
      "comment" : "Storage privacy explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufnahmen werden standardmäßig im lokalen app-privaten Container gespeichert. Wenn iCloud in den Einstellungen aktiviert ist, werden Aufnahmedateien und Index im app-privaten iCloud-Container gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recordings are saved in the local app-private container by default. When iCloud is enabled in Settings, recording files and the index are saved to the app-private iCloud container."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "録音は既定でローカルのアプリ専用コンテナに保存されます。設定でiCloudを有効にすると、録音ファイルとインデックスはアプリ専用iCloudコンテナに保存されます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opnamen worden standaard opgeslagen in de lokale privécontainer van de app. Wanneer iCloud is ingeschakeld in Instellingen, worden opnamebestanden en de index opgeslagen in de app-private iCloud-container."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "默认保存在本机 app 私有容器；只有在设置里开启 iCloud 后，录音文件和索引才会保存到 app 私有 iCloud container。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "錄音預設儲存在本機 app 私有容器；只有在設定裡開啟 iCloud 後，錄音檔案和索引才會儲存到 app 私有 iCloud container。"
          }
