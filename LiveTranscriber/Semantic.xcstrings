    "local_whisper.coreml_encoder.loading.description" : {
      "comment" : "Settings toggle description for enabling local Whisper Core ML encoder loading.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Für die meisten Aufnahmen nicht empfohlen. Kann bei Live-Transkription langsamer oder ungenauer sein. Standardmäßig deaktiviert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Not recommended for most recordings. It can be slower or less accurate in live transcription. Off by default."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ほとんどの録音では推奨しません。ライブ文字起こしでは遅くなったり精度が下がったりする場合があります。デフォルトではオフです。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niet aanbevolen voor de meeste opnamen. Kan bij live transcriptie trager of minder nauwkeurig zijn. Standaard uit."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大多数录音不推荐开启。实时转录时可能更慢或准确度更低。默认关闭。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大多數錄音不建議開啟。即時轉錄時可能更慢或準確度更低。預設關閉。"
          }
        }
      }
    },
