    "settings.privacy.developer_cannot_access_content" : {
      "comment" : "Privacy explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Audio und Transkripte werden nicht auf Entwickler-Server hochgeladen, und der Entwickler kann nicht auf Benutzerinhalte zugreifen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Audio and transcripts are not uploaded to developer servers, and the developer cannot access user content."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音声と文字起こしは開発者のサーバーにアップロードされず、開発者はユーザーのコンテンツにアクセスできません。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Audio en transcripties worden niet naar ontwikkelaarsservers geüpload en de ontwikkelaar heeft geen toegang tot gebruikersinhoud."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音频和转录不会上传到开发者服务器，开发者无法访问用户内容。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音訊和轉錄不會上傳到開發者伺服器，開發者無法存取使用者內容。"
          }
        }
      }
    },
    "settings.privacy.no_developer_servers" : {
      "comment" : "Privacy explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es werden keine vom Entwickler betriebenen Server, keine Drittanbieter-Analysen, keine Werbung und kein Tracking verwendet. Optionale Cloud-Aktionen verbinden dieses iPhone direkt mit dem ausgewählten Anbieter."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No developer-operated servers, third-party analytics, ads, or tracking are used. Optional cloud actions connect directly from this iPhone to the selected provider."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "開発者運用サーバー、サードパーティ分析、広告、トラッキングは使用しません。任意のクラウド操作は、このiPhoneから選択したプロバイダへ直接接続します。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er worden geen servers van de ontwikkelaar, analyses van derden, advertenties of tracking gebruikt. Optionele cloudacties verbinden deze iPhone rechtstreeks met de gekozen provider."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不使用开发者运营的服务器、第三方分析、广告或追踪。可选的云端操作会由这台 iPhone 直接连接所选提供商。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不使用開發者營運的伺服器、第三方分析、廣告或追蹤。可選的雲端操作會由這台 iPhone 直接連線所選供應商。"
          }
        }
      }
    },
    "settings.privacy.on_device_processing" : {
      "comment" : "Privacy explanation.",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Verarbeitung erfolgt standardmäßig lokal. Audio oder Transkripttext wird nur nach Aktivierung und ausdrücklicher Auswahl der Gemini-Cloud-Aktion an Gemini gesendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Processing is local by default. Audio or transcript text is sent to Gemini only after you enable and explicitly choose the related cloud action."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "処理は既定でローカルです。Geminiのクラウド操作を有効にして明示的に選択した場合にのみ、音声または文字起こしがGeminiへ送信されます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwerking is standaard lokaal. Audio of transcripttekst wordt alleen naar Gemini gestuurd nadat je de Gemini-cloudactie inschakelt en expliciet kiest."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "默认在本地处理。只有在你启用并明确选择 Gemini 云端操作后，音频或转录文本才会发送至 Gemini。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "預設在本機處理。只有在你啟用並明確選擇 Gemini 雲端操作後，音訊或轉錄文字才會傳送至 Gemini。"
          }
        }
      }
    },
