    "settings.privacy.developer_cannot_access_content": {
      "comment": "Privacy explanation.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio and transcripts are not uploaded to developer servers, and the developer cannot access user content."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "音频和转录不会上传到开发者服务器，开发者无法访问用户内容。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio und Transkripte werden nicht auf Entwickler-Server hochgeladen, und der Entwickler kann nicht auf Benutzerinhalte zugreifen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio en transcripties worden niet naar ontwikkelaarsservers geüpload en de ontwikkelaar heeft geen toegang tot gebruikersinhoud."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声と文字起こしは開発者のサーバーにアップロードされず、開発者はユーザーのコンテンツにアクセスできません。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "音訊和轉錄不會上傳到開發者伺服器，開發者無法存取使用者內容。"
          }
        }
      }
    },
    "settings.privacy.no_developer_servers": {
      "comment": "Privacy explanation.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No developer-operated servers, third-party analytics, ads, tracking, or custom network requests are used."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不使用开发者服务器、第三方分析、广告、追踪或自定义网络请求。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es werden keine vom Entwickler betriebenen Server, Drittanbieteranalysen, Werbung, Tracking oder eigenen Netzwerkanfragen verwendet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er worden geen door ontwikkelaars beheerde servers, analytics van derden, advertenties, tracking of aangepaste netwerkverzoeken gebruikt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "開発者運営のサーバー、サードパーティ分析、広告、トラッキング、独自のネットワークリクエストは使用されません。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "不使用開發者伺服器、第三方分析、廣告、追蹤或自訂網路請求。"
          }
        }
      }
    },
    "settings.privacy.on_device_processing": {
      "comment": "Privacy explanation.",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recordings, transcripts, summaries, and tags are processed on device with Apple system frameworks."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "录音、转录文本、摘要和标签使用 Apple 系统框架在设备上处理。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aufnahmen, Transkripte, Zusammenfassungen und Tags werden mit Apple-Systemframeworks auf dem Gerät verarbeitet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opnamen, transcripties, samenvattingen en tags worden op het apparaat verwerkt met Apple-systeemframeworks."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "録音、文字起こし、要約、タグはAppleのシステムフレームワークを使ってデバイス上で処理されます。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "錄音、轉錄文字、摘要和標籤會使用 Apple 系統框架在裝置上處理。"
          }
        }
      }
    },
